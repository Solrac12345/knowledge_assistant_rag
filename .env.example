# EN: Environment configuration for the RAG Knowledge Assistant
# FR: Configuration d'environnement pour l'Assistant RAG
#
# EN: Copy this file to .env and fill in your values.
# FR: Copiez ce fichier vers .env et remplissez vos valeurs.

ENVIRONMENT=development

# EN: Path where ChromaDB will store vector data (relative or absolute)
# FR: Chemin où ChromaDB stockera les données vectorielles (relatif ou absolu)
CHROMA_DB_PATH=data/chroma

# EN: Embedding model used for vectorization
# FR: Modèle d'embedding utilisé pour la vectorisation
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# EN: LLM API configuration (optional)
# FR: Configuration API pour le LLM (optionnel)
# EN: Example: LLM_API_KEY=sk-xxx
# FR: Exemple : LLM_API_KEY=sk-xxx
LLM_API_KEY=
LLM_BASE_URL=

# LLM provider: "dummy" or "ollama"
LLM_PROVIDER=dummy
